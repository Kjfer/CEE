# Activa la capa de datos simulada. "true" = usar mocks; "false" = consumir Supabase real.
VITE_USE_MOCKS=true
# Proyecto de Supabase (Project Settings > API). Requeridos cuando VITE_USE_MOCKS=false.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# El Asistente CEE y el debug de consulta de datos (/debug/consulta-datos) llaman
# a las funciones serverless propias en apps/admin/api/ (rutas relativas /api/*,
# sin variable de entorno). GROQ_API_KEY, SUPABASE_URL y SUPABASE_KEY se
# configuran SOLO como variables de entorno del proyecto de Vercel (nunca con
# prefijo VITE_, nunca en este archivo).
