# Activa la capa de datos simulada. "true" = usar mocks; "false" = consumir Supabase real.
VITE_USE_MOCKS=true
# Proyecto de Supabase (Project Settings > API). Requeridos cuando VITE_USE_MOCKS=false.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# URL del servidor bot (apps/bot). Requerido para el Asistente CEE y para el
# debug de consulta de datos (/debug/consulta-datos). La clave de Groq vive
# SOLO en apps/bot (GROQ_API_KEY, sin prefijo VITE_) — nunca en este archivo.
VITE_BOT_URL=http://localhost:3000
